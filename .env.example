# ============================================================
# One Person Company - Environment Template
# Source of truth: DOCS.md
# ============================================================

# =========================
# Core (Required)
# =========================
# Supabase Dashboard -> Settings -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key

# =========================
# Engine Runtime
# =========================
# Run recently missed daily tasks on startup (default: 1)
ENGINE_CATCH_UP_ON_START=1
# Minutes-back window for startup catch-up (default: 180)
ENGINE_CATCH_UP_MINUTES=180
# Run interval-based jobs once at startup (default: 1)
ENGINE_RUN_INTERVAL_ON_START=1

# =========================
# Discord (CEO/Agent Comms)
# =========================
# Discord Developer Portal -> Applications
DISCORD_BOT_TOKEN=your-discord-bot-token

# Optional legacy fallback channel
DISCORD_CHANNEL_ID=your-default-channel-id

# Main channels
DISCORD_GENERAL_CHANNEL_ID=your-general-channel-id
DISCORD_STANDUP_CHANNEL_ID=your-standup-channel-id
DISCORD_MAILS_CHANNEL_ID=your-mails-channel-id

# Restrict inbound processing to one CEO user (recommended)
DISCORD_CEO_USER_ID=your-discord-user-id

# Default assignee when message has no explicit target (default in code: watari)
DISCORD_DEFAULT_AGENT_ID=watari

# Optional per-agent bot tokens
DISCORD_WATARI_BOT_TOKEN=your-watari-bot-token
DISCORD_STRATEGIST_LEAD_BOT_TOKEN=your-strategist-bot-token
DISCORD_CREATOR_LEAD_BOT_TOKEN=your-creator-bot-token
DISCORD_ANALYST_LEAD_BOT_TOKEN=your-analyst-bot-token

# Optional per-agent Discord user IDs (for mention routing)
DISCORD_WATARI_USER_ID=your-watari-user-id
DISCORD_STRATEGIST_LEAD_USER_ID=your-strategist-user-id
DISCORD_CREATOR_LEAD_USER_ID=your-creator-user-id
DISCORD_ANALYST_LEAD_USER_ID=your-analyst-user-id

# Polling/behavior
# Minimum enforced is 15s (default: 60)
DISCORD_POLL_SECONDS=60
# 0 = don't replay old messages after restart (default)
# 1 = process existing recent messages on startup
DISCORD_PROCESS_EXISTING_ON_START=0
# Optional REST timeout (seconds, default: 15)
DISCORD_HTTP_TIMEOUT_SECONDS=15

# =========================
# Email (Optional, for email_ops)
# =========================
# IMAP (inbound)
EMAIL_IMAP_HOST=imap.your-email.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=you@your-email.com
EMAIL_IMAP_PASSWORD=your-imap-password
EMAIL_IMAP_SSL=1
EMAIL_IMAP_FOLDER=INBOX

# SMTP (outbound)
EMAIL_SMTP_HOST=smtp.your-email.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=you@your-email.com
EMAIL_SMTP_PASSWORD=your-smtp-password
EMAIL_SMTP_SSL=1
EMAIL_FROM=you@your-email.com
EMAIL_REPLY_TO=optional-reply-to@your-email.com

# =========================
# Twitter (Optional, for publish_content/fetch_metrics)
# =========================
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret

# =========================
# Reddit (Optional)
# =========================
# Current surf_reddit uses public endpoints, so these are optional.
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=one-person-company/1.0

# =========================
# Database / Ops (Optional)
# =========================
DATABASE_URL=postgresql://postgres:password@db.project.supabase.co:5432/postgres
CRON_SECRET=your-random-cron-secret
