# Supabase Configuration (REQUIRED)
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# OpenAI Configuration (REQUIRED)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Twitter API (Optional - for posting)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Reddit API (Optional - for scanning)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Database URL (Optional - for direct psql access)
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# Cron Secret (Optional - for scheduled tasks)
CRON_SECRET=your-random-secret-here

# Email Configuration (REQUIRED for CEO standup)
# For Gmail: enable "App Passwords" in Google Account settings
# SMTP: for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# IMAP: for receiving email replies
IMAP_HOST=imap.gmail.com
# Your bot email address (sends standup emails)
EMAIL_ADDRESS=your-bot-email@gmail.com
EMAIL_PASSWORD=your-app-password-here
# CEO email address (receives standups)
CEO_EMAIL=your-email@gmail.com

