# Supabase Configuration (REQUIRED)
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# OpenAI Configuration (REQUIRED)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Twitter API (REQUIRED for ingestion and publishing)
# Get from: https://developer.twitter.com/en/portal/dashboard
# You need: API Key & Secret, Bearer Token, Access Token & Secret
# Permissions: Read and Write
TWITTER_API_KEY=your-api-key-here
TWITTER_API_SECRET=your-api-secret-here
TWITTER_BEARER_TOKEN=your-bearer-token-here
TWITTER_ACCESS_TOKEN=your-access-token-here
TWITTER_ACCESS_SECRET=your-access-secret-here

# Reddit API (REQUIRED for ingestion)
# Get from: https://www.reddit.com/prefs/apps
# Create an app (script type) and get client ID & secret
REDDIT_CLIENT_ID=your-client-id-here
REDDIT_CLIENT_SECRET=your-client-secret-here

# Database URL (Optional - for direct psql access)
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# Cron Secret (Optional - for scheduled tasks)
CRON_SECRET=your-random-secret-here

# Email Configuration (REQUIRED for CEO standup)
# For Gmail: enable "App Passwords" in Google Account settings
# SMTP: for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# IMAP: for receiving email replies
IMAP_HOST=imap.gmail.com
# Your bot email address (sends standup emails)
EMAIL_ADDRESS=your-bot-email@gmail.com
EMAIL_PASSWORD=your-app-password-here
# CEO email address (receives standups)
CEO_EMAIL=your-email@gmail.com

# Inbox polling interval in seconds (engine email check loop)
# Minimum enforced value is 15 seconds. Default is 60.
EMAIL_POLL_SECONDS=60
