# Supabase Configuration (REQUIRED)
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# OpenAI Configuration (REQUIRED)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Twitter API (REQUIRED for ingestion and publishing)
# Get from: https://developer.twitter.com/en/portal/dashboard
# You need: API Key & Secret, Bearer Token, Access Token & Secret
# Permissions: Read and Write
TWITTER_API_KEY=your-api-key-here
TWITTER_API_SECRET=your-api-secret-here
TWITTER_BEARER_TOKEN=your-bearer-token-here
TWITTER_ACCESS_TOKEN=your-access-token-here
TWITTER_ACCESS_SECRET=your-access-secret-here

# Reddit API (OPTIONAL - surf_reddit currently uses public endpoints)
# Keep these only if you plan to add OAuth-backed Reddit features later.
REDDIT_CLIENT_ID=your-client-id-here
REDDIT_CLIENT_SECRET=your-client-secret-here

# Database URL (Optional - for direct psql access)
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# Cron Secret (Optional - for scheduled tasks)
CRON_SECRET=your-random-secret-here

# Discord Configuration (REQUIRED for CEO/agent communication)
# Create bot(s) at https://discord.com/developers/applications
# Recommended for your setup: exactly two channels -> #general and #standup.
# Global bot token fallback (used if per-agent token is not set):
DISCORD_BOT_TOKEN=your-discord-bot-token
# Optional legacy fallback channel:
DISCORD_CHANNEL_ID=your-default-channel-id
# Main inbound/outbound channel for normal queries:
DISCORD_GENERAL_CHANNEL_ID=your-general-channel-id
# Standup reporting channel:
DISCORD_STANDUP_CHANNEL_ID=your-standup-channel-id
# Email updates channel (for #mails):
DISCORD_MAILS_CHANNEL_ID=your-mails-channel-id
# Optional: restrict inbound processing to your Discord user ID only.
DISCORD_CEO_USER_ID=your-discord-user-id
# Optional default assignee for untargeted messages in #general.
# If omitted, defaults to strategist_lead.
DISCORD_DEFAULT_AGENT_ID=strategist_lead

# Optional per-agent bot tokens (if each agent has its own bot)
DISCORD_STRATEGIST_LEAD_BOT_TOKEN=your-strategist-bot-token
DISCORD_CREATOR_LEAD_BOT_TOKEN=your-creator-bot-token
DISCORD_ANALYST_LEAD_BOT_TOKEN=your-analyst-bot-token

# Polling interval in seconds for Discord check loop.
# Minimum enforced value is 15 seconds. Default is 60.
DISCORD_POLL_SECONDS=60
# Startup replay behavior:
# 0 (default) = do NOT replay old general-channel messages after restart
# 1 = process existing recent messages on startup
DISCORD_PROCESS_EXISTING_ON_START=0

# Email (IMAP/SMTP) Configuration (OPTIONAL - for email_ops tool)
# IMAP (inbound)
EMAIL_IMAP_HOST=imap.your-email.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=you@your-email.com
EMAIL_IMAP_PASSWORD=your-imap-password
EMAIL_IMAP_SSL=1
EMAIL_IMAP_FOLDER=INBOX

# SMTP (outbound)
EMAIL_SMTP_HOST=smtp.your-email.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=you@your-email.com
EMAIL_SMTP_PASSWORD=your-smtp-password
EMAIL_SMTP_SSL=1
EMAIL_FROM=you@your-email.com
EMAIL_REPLY_TO=optional-reply-to@your-email.com
